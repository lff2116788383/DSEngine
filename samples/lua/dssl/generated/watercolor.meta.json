{
  "shader_type": "surface",
  "has_light": false,
  "render_modes": {
    "blend": "blend_mix",
    "cull": "cull_back",
    "depth_draw": "depth_draw_opaque",
    "shadows_enabled": true,
    "alpha_test": false
  },
  "uniforms": [
    {"name": "albedo_color", "type": "vec4", "default": "vec4(0.85, 0.65, 0.45, 1.0)", "hints": ["color"]},
    {"name": "albedo_tex", "type": "sampler2D", "is_sampler": true, "hints": ["filter_linear_mipmap", "white_default"]},
    {"name": "paper_strength", "type": "float", "default": "0.3", "hints": ["range(0.0", "1.0)"]},
    {"name": "edge_darkening", "type": "float", "default": "0.4", "hints": ["range(0.0", "1.0)"]},
    {"name": "color_bleed", "type": "float", "default": "0.2", "hints": ["range(0.0", "1.0)"]},
    {"name": "pigment_density", "type": "float", "default": "1.0", "hints": ["range(0.1", "2.0)"]}
  ]
}
