{
  "shader_type": "surface",
  "has_light": false,
  "render_modes": {
    "blend": "blend_mix",
    "cull": "cull_back",
    "depth_draw": "depth_draw_opaque",
    "shadows_enabled": true,
    "alpha_test": false
  },
  "uniforms": [
