    {"name": "albedo_tex", "type": "sampler2D", "is_sampler": true, "hints": ["filter_linear_mipmap", "white_default"]},
    {"name": "shadow_color", "type": "vec4", "default": "vec4(0.08, 0.06, 0.12, 1.0)", "hints": ["color"]},
    {"name": "shadow_threshold", "type": "float", "default": "0.3", "hints": ["range(0.0", "1.0)"]},
    {"name": "shadow_softness", "type": "float", "default": "0.02", "hints": ["range(0.0", "0.5)"]},
    {"name": "specular_size", "type": "float", "default": "0.85", "hints": ["range(0.0", "1.0)"]},
    {"name": "specular_strength", "type": "float", "default": "1.5", "hints": ["range(0.0", "3.0)"]},
    {"name": "rim_strength", "type": "float", "default": "0.15", "hints": ["range(0.0", "1.0)"]}
  ]
}
