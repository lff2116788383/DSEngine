    {"name": "hatch_density", "type": "float", "default": "30.0", "hints": ["range(5.0", "80.0)"]},
    {"name": "hatch_thickness", "type": "float", "default": "0.4", "hints": ["range(0.1", "0.9)"]}
  ]
