{
  "version": 3,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 21,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "windows-base",
      "hidden": true,
      "description": "Windows 本地：Ninja + MSVC；依赖全部内置于 depends/ 子模块",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/out/build/${presetName}",
      "architecture": {
        "value": "x64",
        "strategy": "external"
      },
      "toolset": {
        "value": "host=x64",
        "strategy": "external"
      },
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      },
      "cacheVariables": {
        "CMAKE_POLICY_VERSION_MINIMUM": "3.5",
        "DSE_BUILD_GTESTS": "ON",
        "DSE_BUILD_EDITOR": "ON",
        "DSE_ENABLE_VULKAN": "ON",
        "DSE_ENABLE_D3D11": "ON"
      }
    },
    {
      "name": "windows-x64-debug",
      "displayName": "x64 Debug",
      "inherits": "windows-base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "windows-x64-relwithdebinfo",
      "displayName": "x64 RelWithDebInfo",
      "inherits": "windows-base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo"
      }
    },
    {
      "name": "windows-x64-release",
      "displayName": "x64 Release",
      "inherits": "windows-base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "wsl-base",
      "hidden": true,
      "description": "WSL/Linux：Ninja + gcc；GLFW X11 + GL 桌面后端（与 CI build-linux 一致）",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/out/build/${presetName}",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      },
      "cacheVariables": {
        "CMAKE_POLICY_VERSION_MINIMUM": "3.5",
        "DSE_BUILD_SHARED": "OFF",
        "DSE_BUILD_GTESTS": "OFF",
        "DSE_BUILD_EDITOR": "OFF",
        "DSE_ENABLE_3D": "ON",
        "DSE_ENABLE_JOLT": "ON",
        "DSE_ENABLE_PHYSX": "OFF",
        "DSE_ENABLE_D3D11": "OFF",
        "DSE_ENABLE_VULKAN": "OFF"
      }
    },
    {
      "name": "wsl-debug",
      "displayName": "WSL Debug",
      "inherits": "wsl-base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "wsl-relwithdebinfo",
      "displayName": "WSL RelWithDebInfo",
      "inherits": "wsl-base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo"
      }
    },
    {
      "name": "wsl-release",
      "displayName": "WSL Release",
      "inherits": "wsl-base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "windows-x64-debug",
      "displayName": "x64 Debug",
      "configurePreset": "windows-x64-debug"
    },
    {
      "name": "windows-x64-relwithdebinfo",
      "displayName": "x64 RelWithDebInfo",
      "configurePreset": "windows-x64-relwithdebinfo"
    },
    {
      "name": "windows-x64-release",
      "displayName": "x64 Release",
      "configurePreset": "windows-x64-release"
    },
    {
      "name": "wsl-debug",
      "displayName": "WSL Debug",
      "configurePreset": "wsl-debug"
    },
    {
      "name": "wsl-relwithdebinfo",
      "displayName": "WSL RelWithDebInfo",
      "configurePreset": "wsl-relwithdebinfo"
    },
    {
      "name": "wsl-release",
      "displayName": "WSL Release",
      "configurePreset": "wsl-release"
    }
  ],
  "testPresets": [
    {
      "name": "windows-x64-debug",
      "displayName": "x64 Debug gtest",
      "configurePreset": "windows-x64-debug",
      "output": {
        "outputOnFailure": true
      },
      "filter": {
        "include": {
          "label": "gtest"
        }
      }
    },
    {
      "name": "windows-x64-relwithdebinfo",
      "displayName": "x64 RelWithDebInfo gtest",
      "configurePreset": "windows-x64-relwithdebinfo",
      "output": {
        "outputOnFailure": true
      },
      "filter": {
        "include": {
          "label": "gtest"
        }
      }
    },
    {
      "name": "windows-x64-release",
      "displayName": "x64 Release gtest",
      "configurePreset": "windows-x64-release",
      "output": {
        "outputOnFailure": true
      },
      "filter": {
        "include": {
          "label": "gtest"
        }
      }
    }
  ]
}
