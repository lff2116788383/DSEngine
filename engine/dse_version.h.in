/**
 * @file dse_version.h
 * @brief DSEngine 版本宏，由 CMake configure_file 自动生成。
 */

#ifndef DSE_VERSION_H
#define DSE_VERSION_H

#define DSE_VERSION_MAJOR @DSEngine_VERSION_MAJOR@
#define DSE_VERSION_MINOR @DSEngine_VERSION_MINOR@
#define DSE_VERSION_PATCH @DSEngine_VERSION_PATCH@

/* 预发布标签，正式版为空字符串 "" */
#define DSE_VERSION_PRERELEASE "@DSEngine_VERSION_PRERELEASE@"

/* 完整 SemVer 版本串，含预发布标签，例如 "0.1.0-alpha" */
#define DSE_VERSION_STRING "@DSEngine_VERSION_STRING@"

#endif // DSE_VERSION_H
