#include "engine/scripting/lua/bindings/lua_binding_modules.h"
#include "engine/scripting/native_api/dse_api.h"
extern "C" {
#include "depends/lua/lauxlib.h"
}

namespace dse::runtime::lua_binding {
namespace {

{% for field in comp.fields %}
{% if field.type == "float" %}
int L_Get_{{ comp.prefix }}_{{ field.name }}(lua_State* L) {
    uint32_t e = static_cast<uint32_t>(luaL_checkinteger(L, 1));
    lua_pushnumber(L, dse_{{ comp.prefix }}_get_{{ field.name }}(e));
    return 1;
}
int L_Set_{{ comp.prefix }}_{{ field.name }}(lua_State* L) {
    uint32_t e = static_cast<uint32_t>(luaL_checkinteger(L, 1));
    dse_{{ comp.prefix }}_set_{{ field.name }}(e, static_cast<float>(luaL_checknumber(L, 2)));
    return 0;
}
{% elif field.type in ("int", "enum_int") %}
int L_Get_{{ comp.prefix }}_{{ field.name }}(lua_State* L) {
    uint32_t e = static_cast<uint32_t>(luaL_checkinteger(L, 1));
    lua_pushinteger(L, dse_{{ comp.prefix }}_get_{{ field.name }}(e));
    return 1;
}
int L_Set_{{ comp.prefix }}_{{ field.name }}(lua_State* L) {
    uint32_t e = static_cast<uint32_t>(luaL_checkinteger(L, 1));
    dse_{{ comp.prefix }}_set_{{ field.name }}(e, static_cast<int>(luaL_checkinteger(L, 2)));
    return 0;
}
{% elif field.type == "bool" %}
int L_Get_{{ comp.prefix }}_{{ field.name }}(lua_State* L) {
    uint32_t e = static_cast<uint32_t>(luaL_checkinteger(L, 1));
    lua_pushboolean(L, dse_{{ comp.prefix }}_get_{{ field.name }}(e));
    return 1;
}
int L_Set_{{ comp.prefix }}_{{ field.name }}(lua_State* L) {
    uint32_t e = static_cast<uint32_t>(luaL_checkinteger(L, 1));
    dse_{{ comp.prefix }}_set_{{ field.name }}(e, lua_toboolean(L, 2));
    return 0;
}
{% elif field.type in ("vec3", "euler_quat") %}
int L_Get_{{ comp.prefix }}_{{ field.name }}(lua_State* L) {
    uint32_t e = static_cast<uint32_t>(luaL_checkinteger(L, 1));
    float x = 0, y = 0, z = 0;
    dse_{{ comp.prefix }}_get_{{ field.name }}(e, &x, &y, &z);
    lua_pushnumber(L, x); lua_pushnumber(L, y); lua_pushnumber(L, z);
    return 3;
}
int L_Set_{{ comp.prefix }}_{{ field.name }}(lua_State* L) {
    uint32_t e = static_cast<uint32_t>(luaL_checkinteger(L, 1));
    dse_{{ comp.prefix }}_set_{{ field.name }}(e,
        static_cast<float>(luaL_checknumber(L, 2)),
        static_cast<float>(luaL_checknumber(L, 3)),
        static_cast<float>(luaL_checknumber(L, 4)));
    return 0;
}
{% elif field.type == "string" %}
{% set buf_size = field.get("buffer_size", 512) %}
int L_Get_{{ comp.prefix }}_{{ field.name }}(lua_State* L) {
    uint32_t e = static_cast<uint32_t>(luaL_checkinteger(L, 1));
    char buf[{{ buf_size }}];
    if (dse_{{ comp.prefix }}_get_{{ field.name }}(e, buf, {{ buf_size }}) <= 0) {
        lua_pushstring(L, "");
        return 1;
    }
    lua_pushstring(L, buf);
    return 1;
}
int L_Set_{{ comp.prefix }}_{{ field.name }}(lua_State* L) {
    uint32_t e = static_cast<uint32_t>(luaL_checkinteger(L, 1));
    dse_{{ comp.prefix }}_set_{{ field.name }}(e, luaL_checkstring(L, 2));
    return 0;
}
{% elif field.type == "vec4" %}
int L_Get_{{ comp.prefix }}_{{ field.name }}(lua_State* L) {
    uint32_t e = static_cast<uint32_t>(luaL_checkinteger(L, 1));
    float x = 0, y = 0, z = 0, w = 0;
    dse_{{ comp.prefix }}_get_{{ field.name }}(e, &x, &y, &z, &w);
    lua_pushnumber(L, x); lua_pushnumber(L, y); lua_pushnumber(L, z); lua_pushnumber(L, w);
    return 4;
}
int L_Set_{{ comp.prefix }}_{{ field.name }}(lua_State* L) {
    uint32_t e = static_cast<uint32_t>(luaL_checkinteger(L, 1));
    dse_{{ comp.prefix }}_set_{{ field.name }}(e,
        static_cast<float>(luaL_checknumber(L, 2)),
        static_cast<float>(luaL_checknumber(L, 3)),
        static_cast<float>(luaL_checknumber(L, 4)),
        static_cast<float>(luaL_optnumber(L, 5, 1.0)));
    return 0;
}
{% endif %}
{% endfor %}

} // namespace

void Register{{ comp.name }}GenBindings(lua_State* L) {
    using namespace helper;
    RegisterBindings(L, {
{% for field in comp.fields %}
        {"{{ field.lua_getter }}", L_Get_{{ comp.prefix }}_{{ field.name }}},
        {"{{ field.lua_setter }}", L_Set_{{ comp.prefix }}_{{ field.name }}},
{% endfor %}
    });
}

} // namespace dse::runtime::lua_binding
