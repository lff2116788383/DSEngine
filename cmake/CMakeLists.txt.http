# ============================================================================
# cmake/CMakeLists.txt.http — 通用异步 HTTP(S) 客户端 (IXWebSocket + OpenSSL TLS)
# ----------------------------------------------------------------------------
# 由根 CMakeLists 在 DSE_ENABLE_NET 同级开关 DSE_ENABLE_HTTP=ON 时 include。
# 产出：
#   - ixwebsocket 静态库（USE_TLS + OpenSSL 后端）
#   - dse_http 静态库（engine/http/*.cpp，封装 IXHttpClient，唯一 include IXWebSocket 之处）
#   - dse_http_smoke 可执行（若 tests/http/http_smoke.cpp 存在）
# 并 set(DSE_HAS_HTTP TRUE) 供根 CMakeLists 链接进 dse_engine。
#
# OpenSSL 依赖（仓库外预构建产物，不入库）：
#   - 默认从 DSE_HTTP_OPENSSL_DIR（CMake/-D 或环境变量）取 install 根，期望含 include/ 与 lib/。
#   - Windows 上由 scripts 预构建（见 NETWORK_GNS_PROGRESS / HTTP 文档）。
#   - Linux/macOS 桌面：未显式给 DIR 时回退到系统 find_package(OpenSSL)。
# ============================================================================

message(STATUS "[http] 配置异步 HTTP 客户端 (IXWebSocket + OpenSSL)")

set(_IXWS_DIR "${CMAKE_SOURCE_DIR}/depends/IXWebSocket")
if(NOT EXISTS "${_IXWS_DIR}/CMakeLists.txt")
    message(WARNING "[http] 未找到 depends/IXWebSocket 子模块，dse_http 未创建。请先 git submodule update --init depends/IXWebSocket")
    return()
endif()

# ── 1) 定位 OpenSSL ──────────────────────────────────────────────────────────
option(DSE_HTTP_AUTO_BUILD_OPENSSL "Windows 上找不到 OpenSSL 时自动调脚本预构建" ON)

if(NOT DSE_HTTP_OPENSSL_DIR AND DEFINED ENV{DSE_HTTP_OPENSSL_DIR})
    set(DSE_HTTP_OPENSSL_DIR "$ENV{DSE_HTTP_OPENSSL_DIR}")
endif()

# Windows：未显式给 DIR 且默认安装位缺失时，自动调脚本预构建一次（幂等；之后秒过）。
# 这样 `cmake -DDSE_ENABLE_HTTP=ON ...` 一条命令即可，无需手动安装 OpenSSL。
if(WIN32 AND NOT DSE_HTTP_OPENSSL_DIR
   AND NOT EXISTS "C:/ossl-win64/install/include/openssl/ssl.h"
   AND DSE_HTTP_AUTO_BUILD_OPENSSL)
    message(STATUS "[http] 未发现 OpenSSL，自动调 scripts/build_windows_openssl.ps1 预构建（首次较慢）...")
    execute_process(
        COMMAND powershell -NoProfile -ExecutionPolicy Bypass
                -File "${CMAKE_SOURCE_DIR}/scripts/build_windows_openssl.ps1"
                -Prefix "C:/ossl-win64/install"
        RESULT_VARIABLE _ossl_rc)
    if(NOT _ossl_rc EQUAL 0)
        message(FATAL_ERROR "[http] OpenSSL 自动预构建失败 (rc=${_ossl_rc})。可手动运行 scripts/build_windows_openssl.ps1，或用 -DDSE_HTTP_OPENSSL_DIR=<dir> 指定，或 -DDSE_HTTP_AUTO_BUILD_OPENSSL=OFF 关闭。")
    endif()
endif()

if(WIN32 AND NOT DSE_HTTP_OPENSSL_DIR AND EXISTS "C:/ossl-win64/install/include/openssl/ssl.h")
    set(DSE_HTTP_OPENSSL_DIR "C:/ossl-win64/install")
endif()

if(DSE_HTTP_OPENSSL_DIR)
    set(OPENSSL_ROOT_DIR        "${DSE_HTTP_OPENSSL_DIR}" CACHE PATH "" FORCE)
    set(OPENSSL_USE_STATIC_LIBS ON CACHE BOOL "" FORCE)
    list(PREPEND CMAKE_PREFIX_PATH "${DSE_HTTP_OPENSSL_DIR}")
endif()
find_package(OpenSSL REQUIRED)
message(STATUS "[http] OpenSSL: ${OPENSSL_VERSION} (${OPENSSL_SSL_LIBRARY})")

# ── 2) IXWebSocket（静态库，开 TLS=OpenSSL，关掉自带 zlib/示例）─────────────────
set(BUILD_SHARED_LIBS OFF CACHE BOOL "" FORCE)
set(USE_TLS           ON  CACHE BOOL "" FORCE)
set(USE_OPEN_SSL      ON  CACHE BOOL "" FORCE)
set(USE_MBED_TLS      OFF CACHE BOOL "" FORCE)
set(USE_ZLIB          OFF CACHE BOOL "" FORCE)
set(USE_WS            OFF CACHE BOOL "" FORCE)
set(USE_TEST          OFF CACHE BOOL "" FORCE)

add_subdirectory("${_IXWS_DIR}" "${CMAKE_BINARY_DIR}/depends/IXWebSocket" EXCLUDE_FROM_ALL)

# 与引擎 /MD(d) CRT 对齐（IXWebSocket 默认可能用 /MT）
if(MSVC AND TARGET ixwebsocket)
    set_property(TARGET ixwebsocket PROPERTY
        MSVC_RUNTIME_LIBRARY "MultiThreaded$<$<CONFIG:Debug>:Debug>DLL")
endif()

# ── 3) 引擎 HTTP 模块 dse_http（唯一 include IXWebSocket 之处）──────────────────
file(GLOB_RECURSE _DSE_HTTP_SRC CONFIGURE_DEPENDS "${CMAKE_SOURCE_DIR}/engine/http/*.cpp")
if(NOT _DSE_HTTP_SRC)
    message(WARNING "[http] engine/http 下无源文件，dse_http 未创建")
    return()
endif()
add_library(dse_http STATIC ${_DSE_HTTP_SRC})
target_include_directories(dse_http
    PUBLIC  "${CMAKE_SOURCE_DIR}"
    PRIVATE "${_IXWS_DIR}")
target_compile_definitions(dse_http PRIVATE DSE_ENABLE_HTTP=1)
target_link_libraries(dse_http PUBLIC ixwebsocket OpenSSL::SSL OpenSSL::Crypto)
target_compile_features(dse_http PUBLIC cxx_std_17)
if(MSVC)
    set_property(TARGET dse_http PROPERTY
        MSVC_RUNTIME_LIBRARY "MultiThreaded$<$<CONFIG:Debug>:Debug>DLL")
    # OpenSSL 静态库在 Windows 需要这些系统库
    target_link_libraries(dse_http PUBLIC crypt32 ws2_32 advapi32 user32 gdi32)
endif()

# ── 4) HTTP 冒烟（本地回环 GET/POST + 可选 https TLS 握手）──────────────────────
if(EXISTS "${CMAKE_SOURCE_DIR}/tests/http/http_smoke.cpp")
    add_executable(dse_http_smoke "${CMAKE_SOURCE_DIR}/tests/http/http_smoke.cpp")
    target_include_directories(dse_http_smoke PRIVATE "${CMAKE_SOURCE_DIR}" "${_IXWS_DIR}")
    target_compile_definitions(dse_http_smoke PRIVATE DSE_ENABLE_HTTP=1)
    target_link_libraries(dse_http_smoke PRIVATE dse_http)
    if(MSVC)
        set_property(TARGET dse_http_smoke PROPERTY
            MSVC_RUNTIME_LIBRARY "MultiThreaded$<$<CONFIG:Debug>:Debug>DLL")
    endif()
endif()

set(DSE_HAS_HTTP TRUE)
message(STATUS "[http] dse_http 已接入 (TLS=OpenSSL ${OPENSSL_VERSION})")
